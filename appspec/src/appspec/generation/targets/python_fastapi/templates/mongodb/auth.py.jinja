@auth_router.post("/register", response_model=UserResponse, status_code=201)
async def register(data: UserRegister):
    db = get_db()
    if await db["_appspec_auth"].find_one({"username": data.username}):
        raise HTTPException(400, "Username already taken")
    doc = {
        "username": data.username,
        "password_hash": hash_password(data.password),
{% if spec.auth.roles %}
        "role": data.role if data.role in {{ spec.auth.roles | tojson }} else "{{ spec.auth.default_role or spec.auth.roles[0] }}",
{% endif %}
        "created_at": datetime.now(timezone.utc),
    }
    result = await db["_appspec_auth"].insert_one(doc)
    doc["_id"] = str(result.inserted_id)
    return doc


@auth_router.post("/login", response_model=TokenResponse)
async def login(form: OAuth2PasswordRequestForm = Depends()):
    db = get_db()
    user = await db["_appspec_auth"].find_one({"username": form.username})
    if not user or not verify_password(form.password, user["password_hash"]):
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Invalid username or password",
            headers={"WWW-Authenticate": "Bearer"},
        )
    token_data = {"sub": user["username"]}
{% if spec.auth.roles %}
    token_data["role"] = user.get("role", "{{ spec.auth.default_role or spec.auth.roles[0] }}")
{% endif %}
    token = create_access_token(token_data)
    return {"access_token": token, "token_type": "bearer"}
{% endif %}
