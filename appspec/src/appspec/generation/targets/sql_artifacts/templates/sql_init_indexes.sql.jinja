-- {{ spec.app_name }} — Index Init (Docker entrypoint)
-- Auto-generated by AppSpec v{{ spec.schema_version }}

{% for entity in spec.entities %}
{% for idx in entity.indexes %}
{% if idx.type.value == "unique" %}
CREATE UNIQUE INDEX IF NOT EXISTS idx_{{ entity.collection }}_{{ idx.name or (idx.keys.keys() | join("_")) }}
    ON {{ entity.collection }} ({{ idx.keys.keys() | join(", ") }});
{% else %}
CREATE INDEX IF NOT EXISTS idx_{{ entity.collection }}_{{ idx.name or (idx.keys.keys() | join("_")) }}
    ON {{ entity.collection }}{% if db.sql_index_type(idx.type) != "btree" %} USING {{ db.sql_index_type(idx.type) }}{% endif %} ({{ idx.keys.keys() | join(", ") }});
{% endif %}
{% endfor %}

{% for field in entity.fields %}
{% if field.is_unique %}
CREATE UNIQUE INDEX IF NOT EXISTS idx_{{ entity.collection }}_{{ field.name }}_unique
    ON {{ entity.collection }} ({{ field.name }});
{% endif %}
{% if field.is_filterable %}
CREATE INDEX IF NOT EXISTS idx_{{ entity.collection }}_{{ field.name }}_filter
    ON {{ entity.collection }} ({{ field.name }});
{% endif %}
{% if field.is_sortable %}
CREATE INDEX IF NOT EXISTS idx_{{ entity.collection }}_{{ field.name }}_sort
    ON {{ entity.collection }} ({{ field.name }});
{% endif %}
{% if field.type.value == "reference" %}
CREATE INDEX IF NOT EXISTS idx_{{ entity.collection }}_{{ field.name }}_fk
    ON {{ entity.collection }} ({{ field.name }});
{% endif %}
{% endfor %}
{% endfor %}
