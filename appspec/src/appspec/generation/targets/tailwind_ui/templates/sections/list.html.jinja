{# List section — activity feed / log style #}
<div id="section-{{ current_section.id }}" class="bg-white rounded-lg border border-gray-200 shadow-sm">
{% if current_section.title %}
  <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
    <h3 class="text-sm font-semibold text-gray-700">{{ current_section.title }}</h3>
    <button data-action="listRefresh" data-section="{{ current_section.id }}" class="text-xs text-indigo-600 hover:text-indigo-800">Refresh</button>
  </div>
{% endif %}
  <ul id="list-items-{{ current_section.id }}" class="divide-y divide-gray-100">
  </ul>
  <div id="list-empty-{{ current_section.id }}" class="hidden p-10 text-center text-gray-400">
    No items yet.
  </div>
</div>
