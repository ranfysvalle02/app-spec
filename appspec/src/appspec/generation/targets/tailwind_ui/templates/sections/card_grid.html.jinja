{# Card grid — responsive card-based data view #}
<div id="section-{{ current_section.id }}" class="space-y-3">
{% if current_section.title %}
  <div class="flex items-center justify-between">
    <h3 class="text-sm font-semibold text-gray-700">{{ current_section.title }}</h3>
    <button onclick="cardGridRefresh('{{ current_section.id }}')" class="text-xs text-indigo-600 hover:text-indigo-800">Refresh</button>
  </div>
{% endif %}
  <div id="cards-{{ current_section.id }}" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-{{ current_section.config.get('columns', 3) }} gap-4">
  </div>
  <div id="cards-empty-{{ current_section.id }}" class="hidden p-10 text-center text-gray-400 bg-white rounded-lg border border-gray-200">
    No records found.
  </div>
</div>
