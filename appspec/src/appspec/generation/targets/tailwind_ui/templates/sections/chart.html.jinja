{# Chart section — Chart.js rendered client-side #}
<div id="section-{{ current_section.id }}" class="bg-white rounded-lg border border-gray-200 shadow-sm p-4">
{% if current_section.title %}
  <h3 class="text-sm font-semibold text-gray-700 mb-3">{{ current_section.title }}</h3>
{% endif %}
  <div class="relative w-full" style="height: 260px;">
    <div id="skeleton-{{ current_section.id }}" class="absolute inset-0 flex items-center justify-center">
      <div class="w-full h-full bg-gray-100 rounded animate-pulse"></div>
    </div>
    <canvas id="canvas-{{ current_section.id }}" style="width:100%!important;height:100%!important;display:block;"></canvas>
  </div>
</div>
