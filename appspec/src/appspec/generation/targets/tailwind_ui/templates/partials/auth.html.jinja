{# Auth screen — shown before app when spec.auth.enabled #}
{% if spec.auth.enabled %}
<div id="auth-screen" class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-50 to-gray-100 p-4">
  <div class="bg-white rounded-xl shadow-lg w-full max-w-sm p-8">
    <h2 class="text-2xl font-bold text-gray-900 text-center mb-1">{{ spec.app_name }}</h2>
    <p class="text-sm text-gray-500 text-center mb-6">Sign in to continue</p>
    <div class="flex gap-2 mb-4">
      <button onclick="showAuthTab('login')" id="auth-login-tab" class="flex-1 py-2 text-sm font-medium rounded-md bg-indigo-600 text-white">Login</button>
      <button onclick="showAuthTab('register')" id="auth-register-tab" class="flex-1 py-2 text-sm font-medium rounded-md bg-gray-100 text-gray-600">Register</button>
    </div>
    <form id="auth-form" onsubmit="handleAuth(event)" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Username</label>
        <input type="text" id="auth-username" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Password</label>
        <input type="password" id="auth-password" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
      </div>
{% if spec.auth.roles %}
      <div id="auth-role-field" class="hidden">
        <label class="block text-sm font-medium text-gray-700">Role</label>
        <select id="auth-role" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
{% for role in spec.auth.roles %}
          <option value="{{ role }}">{{ role }}</option>
{% endfor %}
        </select>
      </div>
{% endif %}
      <div id="auth-error" class="hidden text-sm text-red-600 bg-red-50 rounded-md p-2"></div>
      <button type="submit" class="w-full py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700">
        <span id="auth-btn-text">Sign In</span>
      </button>
    </form>
  </div>
</div>
{% endif %}
