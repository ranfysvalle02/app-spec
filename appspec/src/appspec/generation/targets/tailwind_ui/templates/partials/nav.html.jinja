{# Page-driven navigation — replaces the old entity-tab nav #}
<header class="bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-gray-900">{{ spec.app_name }}</h1>
{% if spec.description %}
      <p class="text-sm text-gray-500 mt-0.5">{{ spec.description }}</p>
{% endif %}
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs text-gray-400">AppSpec v{{ spec.schema_version }}</span>
{% if spec.auth.enabled %}
      <span id="user-badge" class="text-xs bg-indigo-100 text-indigo-700 px-2 py-1 rounded-full"></span>
      <button data-action="logout" class="text-xs text-gray-500 hover:text-red-600">Logout</button>
{% endif %}
    </div>
  </div>
</header>

<nav class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center gap-1 overflow-x-auto" id="page-tabs">
{% for page in pages %}
    <button
      data-page="{{ page.id }}"
      data-action="switchPage"
      class="page-tab px-4 py-3 text-sm font-medium border-b-2 whitespace-nowrap transition-colors
             {{ 'border-indigo-500 text-indigo-600' if page.is_default else 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}"
    >{{ page.label }}</button>
{% endfor %}
  </div>
</nav>
