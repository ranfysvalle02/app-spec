<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ spec.app_name }}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .modal-backdrop { transition: opacity 0.15s ease; }
    .modal-panel { transition: transform 0.15s ease, opacity 0.15s ease; }
    [x-cloak] { display: none !important; }
    .spinner { border: 2px solid #e5e7eb; border-top-color: #6366f1; border-radius: 50%; width: 1.25rem; height: 1.25rem; animation: spin 0.6s linear infinite; display: inline-block; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen">

{% if spec.auth.enabled %}
<!-- ── Auth Screen ────────────────────────────────────────── -->
<div id="auth-screen" class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-50 to-gray-100 p-4">
  <div class="bg-white rounded-xl shadow-lg w-full max-w-sm p-8">
    <h2 class="text-2xl font-bold text-gray-900 text-center mb-1">{{ spec.app_name }}</h2>
    <p class="text-sm text-gray-500 text-center mb-6">Sign in to continue</p>
    <div class="flex gap-2 mb-4">
      <button onclick="showAuthTab('login')" id="auth-login-tab" class="flex-1 py-2 text-sm font-medium rounded-md bg-indigo-600 text-white">Login</button>
      <button onclick="showAuthTab('register')" id="auth-register-tab" class="flex-1 py-2 text-sm font-medium rounded-md bg-gray-100 text-gray-600">Register</button>
    </div>
    <form id="auth-form" onsubmit="handleAuth(event)" class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Username</label>
        <input type="text" id="auth-username" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700">Password</label>
        <input type="password" id="auth-password" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
      </div>
{% if spec.auth.roles %}
      <div id="auth-role-field" class="hidden">
        <label class="block text-sm font-medium text-gray-700">Role</label>
        <select id="auth-role" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
{% for role in spec.auth.roles %}
          <option value="{{ role }}">{{ role }}</option>
{% endfor %}
        </select>
      </div>
{% endif %}
      <div id="auth-error" class="hidden text-sm text-red-600 bg-red-50 rounded-md p-2"></div>
      <button type="submit" class="w-full py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700">
        <span id="auth-btn-text">Sign In</span>
      </button>
    </form>
  </div>
</div>
{% endif %}

<!-- ── App Container ─────────────────────────────────────── -->
<div id="app-container" {% if spec.auth.enabled %}class="hidden"{% endif %}>

<!-- ── Header ────────────────────────────────────────────── -->
<header class="bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-gray-900">{{ spec.app_name }}</h1>
      {% if spec.description %}
      <p class="text-sm text-gray-500 mt-0.5">{{ spec.description }}</p>
      {% endif %}
    </div>
    <div class="flex items-center gap-3">
      <span class="text-xs text-gray-400">AppSpec v{{ spec.schema_version }}</span>
{% if spec.auth.enabled %}
      <span id="user-badge" class="text-xs bg-indigo-100 text-indigo-700 px-2 py-1 rounded-full"></span>
      <button onclick="logout()" class="text-xs text-gray-500 hover:text-red-600">Logout</button>
{% endif %}
    </div>
  </div>
</header>

<!-- ── Entity Tabs ───────────────────────────────────────── -->
<nav class="bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center gap-1 overflow-x-auto" id="entity-tabs">
    {% for entity in spec.entities %}
    <button
      data-collection="{{ entity.collection }}"
      onclick="switchTab('{{ entity.collection }}')"
      class="tab-btn px-4 py-3 text-sm font-medium border-b-2 whitespace-nowrap transition-colors
             {{ 'border-indigo-500 text-indigo-600' if loop.first else 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300' }}"
    >{{ entity.name }}</button>
    {% endfor %}
    <div class="ml-auto flex items-center gap-2 py-2">
      <button onclick="openCreateModal()" class="inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        New
      </button>
    </div>
  </div>
</nav>

<!-- ── Main Content ──────────────────────────────────────── -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 py-6">

  <!-- Filters -->
  <div id="filter-bar" class="flex flex-wrap gap-3 mb-4"></div>

  <!-- Status -->
  <div id="status-bar" class="flex items-center justify-between mb-3">
    <span id="record-count" class="text-sm text-gray-500"></span>
    <div class="flex items-center gap-3">
      <div id="loading-indicator" class="hidden"><span class="spinner"></span></div>
      <button onclick="loadData()" class="text-sm text-indigo-600 hover:text-indigo-800">Refresh</button>
    </div>
  </div>

  <!-- Table -->
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200" id="data-table">
        <thead class="bg-gray-50" id="table-head"></thead>
        <tbody class="divide-y divide-gray-200" id="table-body"></tbody>
      </table>
    </div>
    <div id="empty-state" class="hidden p-12 text-center text-gray-400">
      <p class="text-lg">No records yet</p>
      <p class="text-sm mt-1">Click <strong>New</strong> to create one.</p>
    </div>
  </div>

  <!-- Pagination -->
  <div id="pagination" class="flex items-center justify-between mt-4">
    <button id="prev-btn" onclick="prevPage()" disabled class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed">Previous</button>
    <span id="page-info" class="text-sm text-gray-500"></span>
    <button id="next-btn" onclick="nextPage()" disabled class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed">Next</button>
  </div>
</main>

</div><!-- /app-container -->

<!-- ── Modal ─────────────────────────────────────────────── -->
<div id="modal" class="hidden fixed inset-0 z-50">
  <div class="modal-backdrop fixed inset-0 bg-black/40" onclick="closeModal()"></div>
  <div class="fixed inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div class="modal-panel bg-white rounded-xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto pointer-events-auto">
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
        <h2 id="modal-title" class="text-lg font-semibold"></h2>
        <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="modal-form" class="px-6 py-4 space-y-4" onsubmit="handleSubmit(event)">
        <div id="form-fields"></div>
        <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
          <button type="button" onclick="closeModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">Cancel</button>
          <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-md hover:bg-indigo-700">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ── Delete Confirm ────────────────────────────────────── -->
<div id="delete-modal" class="hidden fixed inset-0 z-50">
  <div class="modal-backdrop fixed inset-0 bg-black/40" onclick="closeDeleteModal()"></div>
  <div class="fixed inset-0 flex items-center justify-center p-4 pointer-events-none">
    <div class="modal-panel bg-white rounded-xl shadow-2xl w-full max-w-sm pointer-events-auto p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-2">Delete Record</h3>
      <p class="text-sm text-gray-500 mb-6">This action cannot be undone. Are you sure?</p>
      <div class="flex justify-end gap-3">
        <button onclick="closeDeleteModal()" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50">Cancel</button>
        <button onclick="confirmDelete()" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-md hover:bg-red-700">Delete</button>
      </div>
    </div>
  </div>
</div>

<!-- ── Toast ──────────────────────────────────────────────── -->
<div id="toast" class="hidden fixed bottom-6 right-6 z-50 px-4 py-3 rounded-lg shadow-lg text-sm font-medium text-white transition-opacity"></div>

<script>
// ── Configuration ──────────────────────────────────────────
const API_BASE = new URLSearchParams(window.location.search).get('api') || '/api';
const AUTH_ENABLED = {{ 'true' if spec.auth.enabled else 'false' }};
const PAGE_SIZE = 50;

// ── Entity Metadata (generated from AppSpec) ───────────────
const ENTITIES = {
{% for entity in spec.entities %}
  '{{ entity.collection }}': {
    name: '{{ entity.name }}',
    collection: '{{ entity.collection }}',
    fields: [
{% for field in entity.fields %}
      {
        name: '{{ field.name }}',
        type: '{{ field.type.value }}',
        required: {{ 'true' if field.required else 'false' }},
        label: '{{ field.name | replace("_", " ") | title }}',
{% if field.enum_values %}
        enumValues: {{ field.enum_values | tojson }},
{% endif %}
{% if field.reference %}
        reference: '{{ field.reference }}',
{% endif %}
{% if field.min_value is not none %}
        min: {{ field.min_value }},
{% endif %}
{% if field.max_value is not none %}
        max: {{ field.max_value }},
{% endif %}
{% if field.max_length %}
        maxLength: {{ field.max_length }},
{% endif %}
        filterable: {{ 'true' if field.is_filterable else 'false' }},
        sortable: {{ 'true' if field.is_sortable else 'false' }},
        unique: {{ 'true' if field.is_unique else 'false' }},
        description: '{{ field.description | replace("'", "\\'") }}',
      },
{% endfor %}
    ],
  },
{% endfor %}
};

const ENTITY_ORDER = [{% for e in spec.entities %}'{{ e.collection }}'{{ ', ' if not loop.last }}{% endfor %}];

// ── State ──────────────────────────────────────────────────
let activeCollection = ENTITY_ORDER[0];
let currentData = [];
let editingId = null;
let deletingId = null;
let sortField = null;
let sortDir = 1;
let filters = {};
let currentSkip = 0;
let refCache = {};

{% if spec.auth.enabled %}
// ── Auth ───────────────────────────────────────────────────
let authMode = 'login';
let authToken = localStorage.getItem('appspec_token');

function showAuthTab(mode) {
  authMode = mode;
  document.getElementById('auth-login-tab').className = mode === 'login'
    ? 'flex-1 py-2 text-sm font-medium rounded-md bg-indigo-600 text-white'
    : 'flex-1 py-2 text-sm font-medium rounded-md bg-gray-100 text-gray-600';
  document.getElementById('auth-register-tab').className = mode === 'register'
    ? 'flex-1 py-2 text-sm font-medium rounded-md bg-indigo-600 text-white'
    : 'flex-1 py-2 text-sm font-medium rounded-md bg-gray-100 text-gray-600';
  document.getElementById('auth-btn-text').textContent = mode === 'login' ? 'Sign In' : 'Create Account';
{% if spec.auth.roles %}
  document.getElementById('auth-role-field').classList.toggle('hidden', mode === 'login');
{% endif %}
  document.getElementById('auth-error').classList.add('hidden');
}

async function handleAuth(e) {
  e.preventDefault();
  const username = document.getElementById('auth-username').value;
  const password = document.getElementById('auth-password').value;
  const errorEl = document.getElementById('auth-error');
  errorEl.classList.add('hidden');

  try {
    if (authMode === 'register') {
      const body = { username, password };
{% if spec.auth.roles %}
      body.role = document.getElementById('auth-role').value;
{% endif %}
      await api('POST', '/auth/register', body);
    }
    const form = new URLSearchParams();
    form.append('username', username);
    form.append('password', password);
    const res = await fetch(`${API_BASE}/auth/login`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: form,
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.detail || err.error || 'Login failed');
    }
    const data = await res.json();
    authToken = data.access_token;
    localStorage.setItem('appspec_token', authToken);
    enterApp();
  } catch (err) {
    errorEl.textContent = err.message;
    errorEl.classList.remove('hidden');
  }
}

function enterApp() {
  document.getElementById('auth-screen').classList.add('hidden');
  document.getElementById('app-container').classList.remove('hidden');
  try {
    const payload = JSON.parse(atob(authToken.split('.')[1]));
    document.getElementById('user-badge').textContent = payload.sub + (payload.role ? ` (${payload.role})` : '');
  } catch {}
  loadData();
}

function logout() {
  authToken = null;
  localStorage.removeItem('appspec_token');
  refCache = {};
  document.getElementById('app-container').classList.add('hidden');
  document.getElementById('auth-screen').classList.remove('hidden');
  document.getElementById('auth-username').value = '';
  document.getElementById('auth-password').value = '';
}
{% endif %}

// ── API Layer ──────────────────────────────────────────────
async function api(method, path, body) {
  const opts = { method, headers: { 'Content-Type': 'application/json' } };
{% if spec.auth.enabled %}
  if (authToken) opts.headers['Authorization'] = `Bearer ${authToken}`;
{% endif %}
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(`${API_BASE}${path}`, opts);
{% if spec.auth.enabled %}
  if (res.status === 401) { logout(); throw new Error('Session expired'); }
{% endif %}
  if (!res.ok) {
    const err = await res.json().catch(() => ({ detail: res.statusText }));
    throw new Error(err.detail || err.error || err.message || res.statusText);
  }
  if (res.status === 204 || method === 'DELETE') {
    return res.status < 300 ? await res.json().catch(() => ({})) : {};
  }
  return res.json();
}

const fetchList   = (coll, skip, limit) => api('GET', `/${coll}?skip=${skip}&limit=${limit}`);
const createOne   = (coll, data) => api('POST', `/${coll}`, data);
const updateOne   = (coll, id, d)=> api('PUT', `/${coll}/${id}`, d);
const deleteOne   = (coll, id)   => api('DELETE', `/${coll}/${id}`);

// ── Reference Resolution ───────────────────────────────────
async function resolveRef(collection, id) {
  if (!id || typeof id !== 'string' || id.length < 12) return id;
  const cacheKey = `${collection}:${id}`;
  if (refCache[cacheKey]) return refCache[cacheKey];
  try {
    const doc = await api('GET', `/${collection}/${id}`);
    const label = doc.name || doc.title || doc.username || doc.label || id;
    refCache[cacheKey] = label;
    return label;
  } catch { refCache[cacheKey] = id; return id; }
}

// ── Tab Switching ──────────────────────────────────────────
function switchTab(collection) {
  activeCollection = collection;
  filters = {};
  sortField = null;
  sortDir = 1;
  currentSkip = 0;
  document.querySelectorAll('.tab-btn').forEach(btn => {
    const active = btn.dataset.collection === collection;
    btn.classList.toggle('border-indigo-500', active);
    btn.classList.toggle('text-indigo-600', active);
    btn.classList.toggle('border-transparent', !active);
    btn.classList.toggle('text-gray-500', !active);
  });
  loadData();
}

// ── Data Loading ───────────────────────────────────────────
async function loadData() {
  const entity = ENTITIES[activeCollection];
  const loader = document.getElementById('loading-indicator');
  loader.classList.remove('hidden');
  try {
    let data = await fetchList(activeCollection, currentSkip, PAGE_SIZE);

    for (const [field, value] of Object.entries(filters)) {
      if (value) data = data.filter(d => String(d[field]) === value);
    }

    if (sortField) {
      data.sort((a, b) => {
        const va = a[sortField] ?? '', vb = b[sortField] ?? '';
        if (typeof va === 'number' && typeof vb === 'number') return (va - vb) * sortDir;
        return String(va).localeCompare(String(vb)) * sortDir;
      });
    }

    currentData = data;
    await renderTable(entity, data);
    renderFilters(entity);
    renderPagination(data.length);
    document.getElementById('record-count').textContent = `${currentSkip + 1}–${currentSkip + data.length} records`;
  } catch (err) {
    showToast(err.message, 'error');
  } finally {
    loader.classList.add('hidden');
  }
}

// ── Pagination ─────────────────────────────────────────────
function renderPagination(count) {
  const pag = document.getElementById('pagination');
  const noPagination = currentSkip === 0 && count < PAGE_SIZE;
  pag.style.display = noPagination ? 'none' : 'flex';
  document.getElementById('prev-btn').disabled = currentSkip === 0;
  document.getElementById('next-btn').disabled = count < PAGE_SIZE;
  const page = Math.floor(currentSkip / PAGE_SIZE) + 1;
  document.getElementById('page-info').textContent = `Page ${page}`;
}

function prevPage() { currentSkip = Math.max(0, currentSkip - PAGE_SIZE); loadData(); }
function nextPage() { currentSkip += PAGE_SIZE; loadData(); }

// ── Table Rendering ────────────────────────────────────────
async function renderTable(entity, data) {
  const head = document.getElementById('table-head');
  const body = document.getElementById('table-body');
  const empty = document.getElementById('empty-state');
  const visibleFields = entity.fields.filter(f => f.type !== 'text');

  head.innerHTML = `<tr>
    ${visibleFields.map(f => `
      <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider
                 ${f.sortable ? 'cursor-pointer hover:text-gray-700 select-none' : ''}"
          ${f.sortable ? `onclick="toggleSort('${f.name}')"` : ''}>
        ${f.label}
        ${f.sortable ? `<span class="ml-1 text-indigo-400">${sortField === f.name ? (sortDir === 1 ? '↑' : '↓') : '⇅'}</span>` : ''}
      </th>`).join('')}
    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider w-24">Actions</th>
  </tr>`;

  if (!data.length) {
    body.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  const refFields = visibleFields.filter(f => f.type === 'reference' && f.reference);
  if (refFields.length) {
    const promises = [];
    for (const doc of data) {
      for (const f of refFields) {
        if (doc[f.name]) promises.push(resolveRef(f.reference, doc[f.name]));
      }
    }
    await Promise.allSettled(promises);
  }

  body.innerHTML = data.map(doc => {
    const id = doc._id || doc.id;
    return `<tr class="hover:bg-gray-50 transition-colors">
      ${visibleFields.map(f => `<td class="px-4 py-3 text-sm text-gray-700 whitespace-nowrap">${formatCell(doc[f.name], f)}</td>`).join('')}
      <td class="px-4 py-3 text-sm text-right whitespace-nowrap">
        <button onclick="openEditModal('${id}')" class="text-indigo-600 hover:text-indigo-800 mr-2">Edit</button>
        <button onclick="openDeleteModal('${id}')" class="text-red-500 hover:text-red-700">Del</button>
      </td>
    </tr>`;
  }).join('');
}

function formatCell(value, field) {
  if (value === null || value === undefined) return '<span class="text-gray-300">—</span>';
  if (field.type === 'reference' && field.reference) {
    const label = refCache[`${field.reference}:${value}`] || value;
    return `<span class="text-indigo-600" title="${value}">${label}</span>`;
  }
  if (field.type === 'boolean') return value
    ? '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Yes</span>'
    : '<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">No</span>';
  if (field.type === 'enum') return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700">${value}</span>`;
  if (field.type === 'datetime') {
    try { return new Date(value).toLocaleDateString(); } catch { return value; }
  }
  if (field.type === 'float' || field.type === 'integer') return `<span class="font-mono">${value}</span>`;
  if (typeof value === 'string' && value.length > 60) return value.slice(0, 57) + '…';
  return String(value);
}

// ── Filter Rendering ───────────────────────────────────────
function renderFilters(entity) {
  const bar = document.getElementById('filter-bar');
  const filterFields = entity.fields.filter(f => f.filterable && f.enumValues);
  if (!filterFields.length) { bar.innerHTML = ''; return; }

  bar.innerHTML = filterFields.map(f => `
    <div class="flex items-center gap-2">
      <label class="text-xs font-medium text-gray-500 uppercase">${f.label}</label>
      <select onchange="setFilter('${f.name}', this.value)"
              class="text-sm border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 py-1 px-2">
        <option value="">All</option>
        ${f.enumValues.map(v => `<option value="${v}" ${filters[f.name] === v ? 'selected' : ''}>${v}</option>`).join('')}
      </select>
    </div>`).join('');
}

function setFilter(field, value) {
  if (value) filters[field] = value;
  else delete filters[field];
  currentSkip = 0;
  loadData();
}

function toggleSort(field) {
  if (sortField === field) sortDir *= -1;
  else { sortField = field; sortDir = 1; }
  loadData();
}

// ── Form Rendering ─────────────────────────────────────────
function renderForm(entity, doc = null) {
  const container = document.getElementById('form-fields');
  container.innerHTML = entity.fields.map(f => {
    const val = doc ? (doc[f.name] ?? '') : '';
    const req = f.required ? 'required' : '';
    const id = `field-${f.name}`;

    let input = '';
    switch (f.type) {
      case 'reference':
        input = `<select id="${id}" name="${f.name}" ${req}
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
                   <option value="">Loading...</option>
                 </select>`;
        if (f.reference) {
          (async () => {
            try {
              const resp = await fetch(API_BASE + '/' + f.reference, {
                headers: AUTH_ENABLED && localStorage.getItem('token') ? {'Authorization': 'Bearer ' + localStorage.getItem('token')} : {}
              });
              const items = await resp.json();
              const sel = document.getElementById(id);
              if (!sel) return;
              const displayField = items.length ? Object.keys(items[0]).find(k => k !== '_id' && k !== 'id' && typeof items[0][k] === 'string') || '_id' : '_id';
              sel.innerHTML = '<option value="">Select...</option>' +
                items.map(item => {
                  const itemId = item._id || item.id;
                  const label = item[displayField] || item.name || itemId;
                  return `<option value="${itemId}" ${String(val) === String(itemId) ? 'selected' : ''}>${label}</option>`;
                }).join('');
            } catch(e) {
              const sel = document.getElementById(id);
              if (sel) sel.innerHTML = `<option value="">Error loading</option>`;
            }
          })();
        }
        break;
      case 'enum':
        input = `<select id="${id}" name="${f.name}" ${req}
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">
                   <option value="">Select...</option>
                   ${(f.enumValues||[]).map(v => `<option value="${v}" ${val === v ? 'selected' : ''}>${v}</option>`).join('')}
                 </select>`;
        break;
      case 'boolean':
        input = `<div class="mt-2"><label class="inline-flex items-center gap-2">
                   <input type="checkbox" id="${id}" name="${f.name}" ${val ? 'checked' : ''}
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-4 w-4">
                   <span class="text-sm text-gray-600">Enabled</span></label></div>`;
        break;
      case 'integer':
      case 'float':
        input = `<input type="number" id="${id}" name="${f.name}" value="${val}" ${req}
                   ${f.type === 'float' ? 'step="any"' : 'step="1"'}
                   ${f.min !== undefined ? `min="${f.min}"` : ''} ${f.max !== undefined ? `max="${f.max}"` : ''}
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">`;
        break;
      case 'datetime':
        const dtVal = val ? new Date(val).toISOString().slice(0, 16) : '';
        input = `<input type="datetime-local" id="${id}" name="${f.name}" value="${dtVal}" ${req}
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">`;
        break;
      case 'email':
        input = `<input type="email" id="${id}" name="${f.name}" value="${val}" ${req}
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">`;
        break;
      case 'text':
        input = `<textarea id="${id}" name="${f.name}" rows="3" ${req}
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">${val}</textarea>`;
        break;
      default:
        input = `<input type="text" id="${id}" name="${f.name}" value="${val}" ${req}
                   ${f.maxLength ? `maxlength="${f.maxLength}"` : ''}
                   class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 text-sm py-2 px-3 border">`;
    }

    return `<div>
      <label for="${id}" class="block text-sm font-medium text-gray-700">${f.label}${f.required ? ' <span class="text-red-400">*</span>' : ''}</label>
      ${input}
      ${f.description ? `<p class="mt-1 text-xs text-gray-400">${f.description}</p>` : ''}
    </div>`;
  }).join('');
}

// ── Modal Controls ─────────────────────────────────────────
function openCreateModal() {
  editingId = null;
  const entity = ENTITIES[activeCollection];
  document.getElementById('modal-title').textContent = `New ${entity.name}`;
  renderForm(entity);
  document.getElementById('modal').classList.remove('hidden');
}

function openEditModal(id) {
  editingId = id;
  const entity = ENTITIES[activeCollection];
  const doc = currentData.find(d => (d._id || d.id) === id);
  if (!doc) return;
  document.getElementById('modal-title').textContent = `Edit ${entity.name}`;
  renderForm(entity, doc);
  document.getElementById('modal').classList.remove('hidden');
}

function closeModal() {
  document.getElementById('modal').classList.add('hidden');
  editingId = null;
}

function openDeleteModal(id) {
  deletingId = id;
  document.getElementById('delete-modal').classList.remove('hidden');
}

function closeDeleteModal() {
  document.getElementById('delete-modal').classList.add('hidden');
  deletingId = null;
}

// ── Form Submission ────────────────────────────────────────
async function handleSubmit(e) {
  e.preventDefault();
  const entity = ENTITIES[activeCollection];
  const formData = {};

  entity.fields.forEach(f => {
    const el = document.getElementById(`field-${f.name}`);
    if (!el) return;
    if (f.type === 'boolean') {
      formData[f.name] = el.checked;
    } else if (f.type === 'integer') {
      formData[f.name] = el.value ? parseInt(el.value, 10) : null;
    } else if (f.type === 'float') {
      formData[f.name] = el.value ? parseFloat(el.value) : null;
    } else if (f.type === 'datetime') {
      formData[f.name] = el.value ? new Date(el.value).toISOString() : null;
    } else {
      formData[f.name] = el.value || null;
    }
    if (formData[f.name] === null && !f.required) delete formData[f.name];
  });

  try {
    if (editingId) {
      await updateOne(activeCollection, editingId, formData);
      showToast(`${entity.name} updated`);
    } else {
      await createOne(activeCollection, formData);
      showToast(`${entity.name} created`);
    }
    closeModal();
    loadData();
  } catch (err) {
    showToast(err.message, 'error');
  }
}

async function confirmDelete() {
  if (!deletingId) return;
  const entity = ENTITIES[activeCollection];
  try {
    await deleteOne(activeCollection, deletingId);
    showToast(`${entity.name} deleted`);
    closeDeleteModal();
    loadData();
  } catch (err) {
    showToast(err.message, 'error');
  }
}

// ── Toast ──────────────────────────────────────────────────
function showToast(message, type = 'success') {
  const el = document.getElementById('toast');
  el.textContent = message;
  el.className = `fixed bottom-6 right-6 z-50 px-4 py-3 rounded-lg shadow-lg text-sm font-medium text-white transition-opacity ${type === 'error' ? 'bg-red-600' : 'bg-green-600'}`;
  setTimeout(() => el.classList.add('opacity-0'), 2500);
  setTimeout(() => { el.classList.add('hidden'); el.classList.remove('opacity-0'); }, 3000);
}

// ── Init ───────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
{% if spec.auth.enabled %}
  if (authToken) {
    try {
      const payload = JSON.parse(atob(authToken.split('.')[1]));
      if (payload.exp && payload.exp * 1000 < Date.now()) { logout(); return; }
      enterApp();
    } catch { logout(); }
  }
{% else %}
  loadData();
{% endif %}
});
</script>
