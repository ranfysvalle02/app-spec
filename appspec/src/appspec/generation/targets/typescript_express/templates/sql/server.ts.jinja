/**
 * {{ spec.app_name }} — Express Server (PostgreSQL)
 *
 * Auto-generated by AppSpec v{{ spec.schema_version }}.
 */

import express from "express";
import cors from "cors";
import path from "path";
import { connectDb, closeDb, query } from "./database";
import { router } from "./routes";
{% if spec.auth.enabled %}
import { authRouter } from "./auth";
{% endif %}

const app = express();
const PORT = process.env.PORT || 8000;

app.use(cors());
app.use(express.json());
app.use("/api", router);
{% if spec.auth.enabled %}
app.use("/api/auth", authRouter);
{% endif %}

app.get("/", (_req, res) => {
  res.json({
    app: "{{ spec.app_name }}",
    slug: "{{ spec.slug }}",
    database: "postgresql",
    health: "/health",
    api: "/api",
    ux: "/ux",
  });
});

app.get("/health", async (_req, res) => {
  try {
    await query("SELECT 1");
    res.json({ status: "healthy", app: "{{ spec.slug }}", database: "connected" });
  } catch {
    res.json({ status: "healthy", app: "{{ spec.slug }}", database: "unavailable" });
  }
});

app.get("/ux", (_req, res) => {
  res.sendFile(path.join(__dirname, "..", "static", "index.html"), (err) => {
    if (err) res.redirect("/");
  });
});

async function start() {
  await connectDb();
  app.listen(PORT, () => console.log(`{{ spec.app_name }} running on port ${PORT}`));
}

process.on("SIGTERM", async () => {
  await closeDb();
  process.exit(0);
});

start().catch(console.error);
