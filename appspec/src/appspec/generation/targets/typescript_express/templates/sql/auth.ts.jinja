import { Router, Request, Response, NextFunction } from "express";
import jwt from "jsonwebtoken";
import bcrypt from "bcryptjs";
import { query } from "./database";

const SECRET = (() => {
  const s = process.env.JWT_SECRET_KEY;
  if (!s) throw new Error("JWT_SECRET_KEY environment variable is required");
  return s;
})();
const TOKEN_EXPIRY = parseInt(process.env.ACCESS_TOKEN_EXPIRE_MINUTES || "60", 10);

export interface AuthRequest extends Request {
  user?: { username: string; role?: string };
}

export const authRouter = Router();

authRouter.post("/register", async (req: Request, res: Response) => {
  try {
    const { username, password{% if spec.auth.roles %}, role{% endif %} } = req.body;
    if (!username || !password) {
      res.status(400).json({ error: "username and password required" });
      return;
    }

    const existing = await query("SELECT id FROM _appspec_auth WHERE username = $1", [username]);
    if (existing.rows.length > 0) {
      res.status(409).json({ error: "Username already taken" });
      return;
    }

    const hash = await bcrypt.hash(password, 10);
    const result = await query(
      `INSERT INTO _appspec_auth (id, username, password_hash{% if spec.auth.roles %}, role{% endif %})
       VALUES (gen_random_uuid(), $1, $2{% if spec.auth.roles %}, $3{% endif %}) RETURNING id, username{% if spec.auth.roles %}, role{% endif %}`,
      [username, hash{% if spec.auth.roles %}, role || "{{ spec.auth.default_role or spec.auth.roles[0] }}"{% endif %}]
    );
    res.status(201).json(result.rows[0]);
  } catch (err: any) {
    res.status(500).json({ error: err.message });
  }
});

authRouter.post("/login", async (req: Request, res: Response) => {
  try {
    const { username, password } = req.body;
    if (!username || !password) {
      res.status(400).json({ error: "username and password required" });
      return;
    }

    const result = await query(
      "SELECT id, username, password_hash{% if spec.auth.roles %}, role{% endif %} FROM _appspec_auth WHERE username = $1",
      [username]
    );
    if (result.rows.length === 0) {
      res.status(401).json({ error: "Invalid credentials" });
      return;
    }

    const user = result.rows[0];
    const valid = await bcrypt.compare(password, user.password_hash);
    if (!valid) {
      res.status(401).json({ error: "Invalid credentials" });
      return;
    }

    const token = jwt.sign(
      { sub: user.username{% if spec.auth.roles %}, role: user.role{% endif %} },
      SECRET,
      { expiresIn: TOKEN_EXPIRY * 60 }
    );

    res.json({ access_token: token, token_type: "bearer" });
  } catch (err: any) {
    res.status(500).json({ error: err.message });
  }
});

export function authenticate(req: AuthRequest, res: Response, next: NextFunction): void {
  const header = req.headers.authorization;
  if (!header || !header.startsWith("Bearer ")) {
    res.status(401).json({ error: "Missing or invalid Authorization header" });
    return;
  }

  try {
    const payload = jwt.verify(header.slice(7), SECRET) as any;
    req.user = { username: payload.sub{% if spec.auth.roles %}, role: payload.role{% endif %} };
    next();
  } catch {
    res.status(401).json({ error: "Invalid or expired token" });
  }
}

{% if spec.auth.roles %}
export function authorize(...roles: string[]) {
  return (req: AuthRequest, res: Response, next: NextFunction): void => {
    if (!req.user || !req.user.role || !roles.includes(req.user.role)) {
      res.status(403).json({ error: "Insufficient permissions" });
      return;
    }
    next();
  };
}
