      `UPDATE {{ entity.collection }} SET {% for f in fields %}{{ f }} = ${{ loop.index }}{% if not loop.last %}, {% endif %}{% endfor %}, updated_at = NOW() WHERE id = ${{ fields | length + 1 }} RETURNING *`,
