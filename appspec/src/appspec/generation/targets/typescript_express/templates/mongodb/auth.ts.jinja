{% if spec.auth.enabled %}

import { Router, Request, Response, NextFunction } from "express";
import jwt from "jsonwebtoken";
import bcrypt from "bcryptjs";
import mongoose, { Schema, Document } from "mongoose";

const SECRET = (() => {
  const s = process.env.JWT_SECRET_KEY;
  if (!s) throw new Error("JWT_SECRET_KEY environment variable is required");
  return s;
})();
const TOKEN_EXPIRY = parseInt(process.env.ACCESS_TOKEN_EXPIRE_MINUTES || "60", 10);

export interface IUser extends Document {
  username: string;
  password_hash: string;
{% if spec.auth.roles %}
  role: string;
{% endif %}
  createdAt?: Date;
}

const UserSchema = new Schema<IUser>(
  {
    username: { type: String, required: true, unique: true },
    password_hash: { type: String, required: true },
{% if spec.auth.roles %}
    role: { type: String, default: "{{ spec.auth.default_role or spec.auth.roles[0] }}", enum: [{{ spec.auth.roles | map("tojson") | join(", ") }}] },
{% endif %}
  },
  { timestamps: true }
);

export const User = mongoose.model<IUser>("AuthUser", UserSchema, "_appspec_auth");

export interface AuthRequest extends Request {
  user?: { username: string; role?: string };
}

export function authenticate(req: AuthRequest, res: Response, next: NextFunction): void {
  const header = req.headers.authorization;
  if (!header || !header.startsWith("Bearer ")) {
    res.status(401).json({ error: "Missing or invalid authorization header" });
    return;
  }
  try {
    const payload = jwt.verify(header.slice(7), SECRET) as { sub: string; role?: string };
    req.user = { username: payload.sub, role: payload.role };
    next();
  } catch {
    res.status(401).json({ error: "Invalid or expired token" });
  }
}

{% if spec.auth.roles %}
export function authorize(...allowedRoles: string[]) {
  return (req: AuthRequest, res: Response, next: NextFunction): void => {
    if (!req.user) {
      res.status(401).json({ error: "Not authenticated" });
      return;
    }
    if (!allowedRoles.includes(req.user.role || "")) {
      res.status(403).json({ error: `Role '${req.user.role}' not permitted` });
      return;
    }
    next();
  };
}
{% endif %}

export const authRouter = Router();

authRouter.post("/register", async (req: Request, res: Response) => {
  try {
{% if spec.auth.roles %}
    const { username, password, role } = req.body;
{% else %}
    const { username, password } = req.body;
{% endif %}
    if (!username || !password) {
      res.status(400).json({ error: "Username and password required" });
      return;
    }
    if (await User.findOne({ username })) {
      res.status(400).json({ error: "Username already taken" });
      return;
    }
    const password_hash = await bcrypt.hash(password, 10);
    const doc: Record<string, any> = { username, password_hash };
{% if spec.auth.roles %}
    const validRoles = {{ spec.auth.roles | tojson }};
    doc.role = validRoles.includes(role) ? role : "{{ spec.auth.default_role or spec.auth.roles[0] }}";
{% endif %}
    const user = await User.create(doc);
    res.status(201).json({ _id: user._id, username: user.username{% if spec.auth.roles %}, role: user.role{% endif %} });
  } catch (err: any) {
    res.status(500).json({ error: err.message });
  }
});

authRouter.post("/login", async (req: Request, res: Response) => {
  try {
    const { username, password } = req.body;
    const user = await User.findOne({ username });
    if (!user || !(await bcrypt.compare(password, user.password_hash))) {
      res.status(401).json({ error: "Invalid username or password" });
      return;
    }
    const payload: Record<string, any> = { sub: user.username };
{% if spec.auth.roles %}
    payload.role = user.role;
{% endif %}
    const token = jwt.sign(payload, SECRET, { expiresIn: TOKEN_EXPIRY * 60 });
    res.json({ access_token: token, token_type: "bearer" });
  } catch (err: any) {
    res.status(500).json({ error: err.message });
  }
});
{% endif %}
