/**
 * {{ spec.app_name }} — 00 Collection Setup
 *
 * Auto-generated by AppSpec v{{ spec.schema_version }}.
 * Docker entrypoint: /docker-entrypoint-initdb.d/00-setup.js
 */

const DB_NAME = "{{ spec.slug | replace("-", "_") }}";
db = db.getSiblingDB(DB_NAME);

print(`[00-setup] Creating collections in ${DB_NAME}`);

{% for entity in spec.entities %}
{% if entity.is_time_series %}
// {{ entity.collection }} — time-series collection
try {
  db.createCollection("{{ entity.collection }}", {
    timeseries: {
      timeField: "{{ entity.time_field }}",
{% if entity.meta_field %}
      metaField: "{{ entity.meta_field }}",
{% endif %}
      granularity: "seconds"
    }
  });
  print(`  Created time-series collection: {{ entity.collection }}`);
} catch (e) {
  if (e.codeName === "NamespaceExists") {
    print(`  Collection {{ entity.collection }} already exists, skipping.`);
  } else { throw e; }
}
{% else %}
// {{ entity.collection }}
if (!db.getCollectionNames().includes("{{ entity.collection }}")) {
  db.createCollection("{{ entity.collection }}");
  print(`  Created collection: {{ entity.collection }}`);
} else {
  print(`  Collection {{ entity.collection }} already exists, skipping.`);
}
{% endif %}

{% endfor %}
print("[00-setup] Done.");
