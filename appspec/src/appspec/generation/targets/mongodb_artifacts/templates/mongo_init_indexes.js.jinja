/**
 * {{ spec.app_name }} — 02 Index Creation
 *
 * Auto-generated by AppSpec v{{ spec.schema_version }}.
 * Docker entrypoint: /docker-entrypoint-initdb.d/02-indexes.js
 *
 * Creates indexes from spec: explicit, unique, filterable, sortable, reference.
 * Deduplicates single-field indexes; try/catch prevents one failure from aborting all.
 */

const DB_NAME = "{{ spec.slug | replace("-", "_") }}";
db = db.getSiblingDB(DB_NAME);

print(`[02-indexes] Creating indexes in ${DB_NAME}`);

{% for entity in spec.entities %}
// ── {{ entity.collection }} ──────────────────────────────────────
{% set indexed = [] %}

{% for idx in entity.indexes %}
{% if idx.type.value == "vectorSearch" %}
try {
  db.getCollection("{{ entity.collection }}").createSearchIndex({
    name: "{{ idx.name or (entity.collection ~ '_vector_' ~ loop.index) }}",
    type: "vectorSearch",
    definition: { fields: [
{% for field_name, field_val in idx.keys.items() %}
      { type: "vector", path: "{{ field_name }}", numDimensions: {{ field_val }}, similarity: "cosine" }{% if not loop.last %},{% endif %}

{% endfor %}
    ]}
  });
} catch (e) { print(`  SKIP: {{ entity.collection }} vector — ${e.message}`); }
{% elif idx.type.value == "text" %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    {% set text_keys = {} %}{% for k in idx.keys %}{% set _ = text_keys.update({k: "text"}) %}{% endfor %}{{ text_keys | tojson }},
    { name: "{{ idx.name or (entity.collection ~ '_text_' ~ loop.index) }}"{% if idx.sparse %}, sparse: true{% endif %} }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }} text — ${e.message}`); }
{% else %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    {{ idx.keys | tojson }},
    { name: "{{ idx.name or (entity.collection ~ '_idx_' ~ loop.index) }}"{% if idx.unique or idx.type.value == "unique" %}, unique: true{% endif %}{% if idx.sparse %}, sparse: true{% endif %}{% if idx.expire_after_seconds is not none %}, expireAfterSeconds: {{ idx.expire_after_seconds }}{% endif %}{% if idx.partial_filter %}, partialFilterExpression: {{ idx.partial_filter | tojson }}{% endif %} }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }} explicit — ${e.message}`); }
{% endif %}
{% endfor %}

{% set unique_fields = entity.fields | selectattr("is_unique") | list %}
{% for f in unique_fields %}
{% if indexed.append(f.name) %}{% endif %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    { "{{ f.name }}": 1 },
    { name: "{{ entity.collection }}_{{ f.name }}_unique", unique: true{% if not f.required %}, sparse: true{% endif %} }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }}.{{ f.name }} unique — ${e.message}`); }
{% endfor %}

{% set filterable = entity.fields | selectattr("is_filterable") | list %}
{% for f in filterable %}
{% if f.name not in indexed %}
{% if indexed.append(f.name) %}{% endif %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    { "{{ f.name }}": 1 },
    { name: "{{ entity.collection }}_{{ f.name }}_filter" }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }}.{{ f.name }} filter — ${e.message}`); }
{% endif %}
{% endfor %}

{% set sortable = entity.fields | selectattr("is_sortable") | list %}
{% for f in sortable %}
{% if f.name not in indexed %}
{% if indexed.append(f.name) %}{% endif %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    { "{{ f.name }}": -1 },
    { name: "{{ entity.collection }}_{{ f.name }}_sort" }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }}.{{ f.name }} sort — ${e.message}`); }
{% endif %}
{% endfor %}

{% set references = entity.fields | selectattr("type.value", "equalto", "reference") | list %}
{% for f in references %}
{% if f.name not in indexed %}
{% if indexed.append(f.name) %}{% endif %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    { "{{ f.name }}": 1 },
    { name: "{{ entity.collection }}_{{ f.name }}_ref" }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }}.{{ f.name }} ref — ${e.message}`); }
{% endif %}
{% endfor %}

{% set geo_fields = entity.fields | selectattr("type.value", "equalto", "geo_point") | list %}
{% for f in geo_fields %}
{% if f.name not in indexed %}
{% if indexed.append(f.name) %}{% endif %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    { "{{ f.name }}": "2dsphere" },
    { name: "{{ entity.collection }}_{{ f.name }}_geo" }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }}.{{ f.name }} geo — ${e.message}`); }
{% endif %}
{% endfor %}

{% set text_fields = entity.fields | selectattr("type.value", "equalto", "text") | list %}
{% if text_fields %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    { {% for f in text_fields %}"{{ f.name }}": "text"{% if not loop.last %}, {% endif %}{% endfor %} },
    { name: "{{ entity.collection }}_text" }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }} text — ${e.message}`); }
{% endif %}

{% if filterable or sortable %}
try {
  db.getCollection("{{ entity.collection }}").createIndex(
    { {% for f in filterable %}"{{ f.name }}": 1{% if sortable or not loop.last %}, {% endif %}{% endfor %}{% for f in sortable if f.name not in filterable | map(attribute='name') | list %}"{{ f.name }}": -1{% if not loop.last %}, {% endif %}{% endfor %} },
    { name: "{{ entity.collection }}_esr_compound" }
  );
} catch (e) { print(`  SKIP: {{ entity.collection }} compound — ${e.message}`); }
{% endif %}

print(`  {{ entity.collection }}: indexes done`);

{% endfor %}
print("[02-indexes] Done.");
