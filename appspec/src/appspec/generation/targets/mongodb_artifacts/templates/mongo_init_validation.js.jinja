/**
 * {{ spec.app_name }} — 01 Schema Validation
 *
 * Auto-generated by AppSpec v{{ spec.schema_version }}.
 * Docker entrypoint: /docker-entrypoint-initdb.d/01-validation.js
 *
 * Applies $jsonSchema validation rules to each collection.
 */

const DB_NAME = "{{ spec.slug | replace("-", "_") }}";
db = db.getSiblingDB(DB_NAME);

print(`[01-validation] Applying $jsonSchema validation in ${DB_NAME}`);

{% for entity in spec.entities %}
{% if not entity.is_time_series %}
{% set required_fields = entity.fields | selectattr("required") | map(attribute="name") | list %}
// {{ entity.collection }}
try {
  db.runCommand({
    collMod: "{{ entity.collection }}",
    validator: {
      $jsonSchema: {
        bsonType: "object",
        title: "{{ entity.name }}",
{% if entity.description %}
        description: "{{ entity.description }}",
{% endif %}
{% if required_fields %}
        required: {{ required_fields | tojson }},
{% endif %}
        properties: {
{% for field in entity.fields %}
{% if field.type.value == "string" or field.type.value == "text" or field.type.value == "email" %}
          "{{ field.name }}": {
            bsonType: "string"{% if field.enum_values %},
            enum: {{ field.enum_values | tojson }}{% endif %}{% if field.max_length %},
            maxLength: {{ field.max_length }}{% endif %}{% if field.pattern %},
            pattern: "{{ field.pattern }}"{% endif %}

          }{% if not loop.last %},{% endif %}

{% elif field.type.value == "enum" %}
          "{{ field.name }}": {
            bsonType: "string",
            enum: {{ field.enum_values | tojson }}
          }{% if not loop.last %},{% endif %}

{% elif field.type.value == "integer" %}
          "{{ field.name }}": {
            bsonType: "int"{% if field.min_value is not none %},
            minimum: {{ field.min_value | int }}{% endif %}{% if field.max_value is not none %},
            maximum: {{ field.max_value | int }}{% endif %}

          }{% if not loop.last %},{% endif %}

{% elif field.type.value == "float" %}
          "{{ field.name }}": {
            bsonType: "double"{% if field.min_value is not none %},
            minimum: {{ field.min_value }}{% endif %}{% if field.max_value is not none %},
            maximum: {{ field.max_value }}{% endif %}

          }{% if not loop.last %},{% endif %}

{% elif field.type.value == "boolean" %}
          "{{ field.name }}": { bsonType: "bool" }{% if not loop.last %},{% endif %}

{% elif field.type.value == "datetime" %}
          "{{ field.name }}": { bsonType: "date" }{% if not loop.last %},{% endif %}

{% elif field.type.value == "reference" %}
          "{{ field.name }}": { bsonType: ["objectId", "string"] }{% if not loop.last %},{% endif %}

{% elif field.type.value == "array" %}
          "{{ field.name }}": { bsonType: "array" }{% if not loop.last %},{% endif %}

{% elif field.type.value == "object" %}
          "{{ field.name }}": { bsonType: "object" }{% if not loop.last %},{% endif %}

{% elif field.type.value == "geo_point" %}
          "{{ field.name }}": {
            bsonType: "object",
            properties: {
              type: { bsonType: "string", enum: ["Point"] },
              coordinates: { bsonType: "array" }
            }
          }{% if not loop.last %},{% endif %}

{% elif field.type.value == "vector" %}
          "{{ field.name }}": { bsonType: "array" }{% if not loop.last %},{% endif %}

{% else %}
          "{{ field.name }}": {}{% if not loop.last %},{% endif %}

{% endif %}
{% endfor %}
        }
      }
    },
    validationLevel: "moderate",
    validationAction: "warn"
  });
  print(`  OK: {{ entity.collection }} ({{ entity.fields | length }} fields, {{ required_fields | length }} required)`);
} catch (e) {
  print(`  SKIP: {{ entity.collection }} validation — ${e.message}`);
}

{% endif %}
{% endfor %}
print("[01-validation] Done.");
