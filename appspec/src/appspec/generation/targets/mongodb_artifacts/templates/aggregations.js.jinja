/**
 * {{ spec.app_name }} — Aggregation Pipelines
 *
 * Auto-generated by AppSpec v{{ spec.schema_version }}.
 * Derived from entity relationships (reference fields -> $lookup).
 */

{% for entity in spec.entities %}
{% set refs = entity.fields | selectattr("type.value", "equalto", "reference") | list %}
{% if refs %}
// ── {{ entity.collection }}: join related data ──

db.getCollection("{{ entity.collection }}").aggregate([
{% for ref in refs %}
  {
    $lookup: {
      from: "{{ ref.reference }}",
      localField: "{{ ref.name }}",
      foreignField: "_id",
      as: "{{ ref.reference }}_details"
    }
  },
  {
    $unwind: {
      path: "${{ ref.reference }}_details",
      preserveNullAndEmptyArrays: true
    }
  },
{% endfor %}
  { $limit: 50 }
]);

{% endif %}
{% endfor %}
