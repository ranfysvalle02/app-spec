/**
 * {{ spec.app_name }} — 03 Seed Data
 *
 * Auto-generated by AppSpec v{{ spec.schema_version }}.
 * Docker entrypoint: /docker-entrypoint-initdb.d/03-seed.js
 *
 * Inserts demo documents per collection for development and testing.
 */

const DB_NAME = "{{ spec.slug | replace("-", "_") }}";
db = db.getSiblingDB(DB_NAME);

print(`[03-seed] Inserting demo data into ${DB_NAME}`);

{% macro js_value(val) %}
{% if val is string and val | length >= 20 and "T" in val and val.endswith("Z") %}
new Date("{{ val }}")
{%- elif val is string %}
"{{ val | replace('\\', '\\\\') | replace('"', '\\"') }}"
{%- elif val is number %}
{{ val }}
{%- elif val is sameas true %}
true
{%- elif val is sameas false %}
false
{%- elif val is none %}
null
{%- elif val is mapping %}
{{ val | tojson }}
{%- elif val is iterable %}
{{ val | tojson }}
{%- else %}
{{ val | tojson }}
{%- endif %}
{% endmacro %}

{% if spec.sample_data %}
{% for entity in spec.entities %}
{% set docs = spec.sample_data.get(entity.collection, []) %}
{% if docs %}
// ── {{ entity.name }} ({{ entity.collection }}) — {{ docs | length }} documents ──
try {
  const {{ entity.collection }}Result = db.getCollection("{{ entity.collection }}").insertMany([
{% for doc in docs %}
    {
{% for key, val in doc.items() %}
      {{ key }}: {{ js_value(val) }},
{% endfor %}
      updated_at: new Date()
    }{% if not loop.last %},{% endif %}

{% endfor %}
  ]);
  print("  OK: {{ entity.collection }} — " + Object.values({{ entity.collection }}Result.insertedIds).length + " documents inserted");
} catch (e) {
  print("  SKIP: {{ entity.collection }} seed — " + e.message);
}

{% endif %}
{% endfor %}
{% else %}
print("  [WARN] No sample_data in spec — skipping seed.");
{% endif %}

// Summary
{% for entity in spec.entities %}
print("  {{ entity.collection }}: " + db.getCollection("{{ entity.collection }}").countDocuments() + " total documents");
{% endfor %}

print("[03-seed] Done.");
